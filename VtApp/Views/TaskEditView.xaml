<UserControl x:Class="VtApp.Views.TaskEditView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:controls="clr-namespace:VtApp.Controls"
             xmlns:converters="clr-namespace:VtApp.Converters"
             xmlns:sys="clr-namespace:System;assembly=System.Runtime"
             mc:Ignorable="d"
             d:DesignHeight="600"
             d:DesignWidth="1000">
    <UserControl.Resources>
        <converters:EnumToIntConverter x:Key="EnumToIntConverter" />
        <converters:TaskPriorityToBrushConverter x:Key="TaskPriorityToBrushConverter" />
        <converters:ProgressAtLeastConverter x:Key="ProgressAtLeastConverter" />

        <Style x:Key="FactorLabelStyle" TargetType="TextBlock"
               BasedOn="{StaticResource MaterialDesignCaptionTextBlock}">
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="Opacity" Value="0.7" />
            <Setter Property="Margin" Value="0,0,0,8" />
        </Style>

        <Style x:Key="SubtaskFlatTextBoxStyle" TargetType="TextBox"
               BasedOn="{StaticResource MaterialDesignTextBoxBase}">
            <Setter Property="Padding" Value="0" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="Transparent" />
        </Style>
    </UserControl.Resources>
    <Grid>
        <TabControl HorizontalContentAlignment="Left"
                    Style="{StaticResource MaterialDesignFilledTabControl}">
            <TabControl.Resources>
                <Style TargetType="{x:Type TabPanel}">
                    <Setter Property="HorizontalAlignment" Value="Left" />
                </Style>
            </TabControl.Resources>

            <TabItem ToolTip="Задача">
                <TabItem.Header>
                    <materialDesign:PackIcon Kind="FormatListChecks"
                                             Width="24"
                                             Height="24" />
                </TabItem.Header>
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              Margin="0,25,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" MinWidth="220" />
                            <ColumnDefinition Width="1.4*" MinWidth="240" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <!-- Left: title + due date + goals -->
                        <StackPanel Grid.Column="0"
                                    VerticalAlignment="Top"
                                    Margin="0,5,12,0">
                            <TextBox Text="{Binding Title, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                     materialDesign:HintAssist.Hint="Название"
                                     Margin="0,0,0,16" />

                            <DatePicker SelectedDate="{Binding DueDate, Mode=TwoWay}"
                                        Style="{StaticResource MaterialDesignOutlinedDatePicker}"
                                        materialDesign:HintAssist.Hint="Срок"
                                        Language="ru-RU"
                                        Margin="0,0,0,30" />

                            <TextBlock Text="Цели"
                                       Style="{StaticResource MaterialDesignBody2TextBlock}"
                                       Opacity="0.7"
                                       Margin="0,0,0,0" />

                            <ItemsControl ItemsSource="{Binding Goals}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBox Text="{Binding Text, UpdateSourceTrigger=PropertyChanged}"
                                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                                 materialDesign:HintAssist.Hint="Цель"
                                                 Margin="0,8,0,0" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>

                        <!-- Center: description -->
                        <TextBox Grid.Column="1"
                                 Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 materialDesign:HintAssist.Hint="Описание"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto"
                                 VerticalContentAlignment="Top"
                                 Margin="0,5,12,0"
                                 MinHeight="280" />

                        <!-- Right: factors card -->
                        <materialDesign:Card Grid.Column="2"
                                             Width="280"
                                             Padding="20,16"
                                             VerticalAlignment="Top"
                                             UniformCornerRadius="8">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal"
                                            HorizontalAlignment="Center"
                                            Margin="0,0,0,16">
                                    <TextBlock Text="Приоритет"
                                               Style="{StaticResource MaterialDesignBody2TextBlock}"
                                               VerticalAlignment="Center"
                                               Opacity="0.7"
                                               Margin="0,0,12,0" />
                                    <materialDesign:Chip Content="{Binding PriorityDisplay}"
                                                         Background="{Binding Priority, Converter={StaticResource TaskPriorityToBrushConverter}}"
                                                         Foreground="White"
                                                         IsDeletable="False" />
                                </StackPanel>

                                <Grid Margin="0,0,0,20" Height="168">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Важность"
                                                   Style="{StaticResource FactorLabelStyle}" />
                                        <controls:LevelBar Value="{Binding Importance, Converter={StaticResource EnumToIntConverter}, Mode=TwoWay}"
                                                           Maximum="3"
                                                           BarOrientation="Vertical"
                                                           Height="140" />
                                    </StackPanel>

                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="Срочность"
                                                   Style="{StaticResource FactorLabelStyle}" />
                                        <controls:LevelBar Value="{Binding Urgency, Converter={StaticResource EnumToIntConverter}, Mode=TwoWay}"
                                                           Maximum="2"
                                                           BarOrientation="Vertical"
                                                           Height="140" />
                                    </StackPanel>

                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="Сложность"
                                                   Style="{StaticResource FactorLabelStyle}" />
                                        <controls:LevelBar Value="{Binding Difficulty, Converter={StaticResource EnumToIntConverter}, Mode=TwoWay}"
                                                           Maximum="2"
                                                           BarOrientation="Vertical"
                                                           Height="140" />
                                    </StackPanel>
                                </Grid>

                                <TextBlock Text="{Binding ProgressLabel}"
                                           Style="{StaticResource MaterialDesignBody2TextBlock}"
                                           Opacity="0.7"
                                           Margin="0,0,0,4" />
                                <Slider Minimum="0"
                                        Maximum="100"
                                        Value="{Binding ProgressPercent, Mode=TwoWay}"
                                        Margin="0,0,0,12" />

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                               Text="Срыв сроков"
                                               Style="{StaticResource MaterialDesignBody2TextBlock}"
                                               Opacity="0.7"
                                               VerticalAlignment="Center"
                                               Margin="0,0,12,0" />
                                    <controls:LevelBar Grid.Column="1"
                                                       Value="{Binding DelayRisk, Converter={StaticResource EnumToIntConverter}, Mode=TwoWay}"
                                                       Maximum="2"
                                                       BarOrientation="Horizontal"
                                                       VerticalAlignment="Center" />
                                </Grid>
                            </StackPanel>
                        </materialDesign:Card>
                    </Grid>

                    <StackPanel Grid.Row="1"
                                Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                Margin="0,30,0,0">
                        <Button Content="Отмена"
                                Style="{StaticResource MaterialDesignOutlinedButton}"
                                Margin="0,0,8,0"
                                Command="{Binding CancelCommand}" />
                        <Button Content="Сохранить"
                                Style="{StaticResource MaterialDesignRaisedButton}"
                                Command="{Binding SaveCommand}" />
                    </StackPanel>

                    <!-- Subtasks at the bottom -->
                    <StackPanel Grid.Row="2" Margin="0,16,0,0">
                        <TextBlock Text="{Binding SubtasksProgressLabel}"
                                   Style="{StaticResource MaterialDesignSubtitle1TextBlock}"
                                   Margin="0,0,0,8" />

                        <ItemsControl ItemsSource="{Binding Subtasks}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="#E0E0E0"
                                            BorderThickness="0,0,0,1"
                                            Padding="0,6"
                                            Background="Transparent">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <CheckBox Grid.Column="0"
                                                      IsChecked="{Binding IsDone, Mode=TwoWay}"
                                                      VerticalAlignment="Center"
                                                      Margin="0,0,8,0" />

                                            <TextBox Grid.Column="1"
                                                     Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}"
                                                     FontSize="14"
                                                     Margin="0,0,12,0"
                                                     VerticalAlignment="Center">
                                                <TextBox.Style>
                                                    <Style TargetType="TextBox" BasedOn="{StaticResource SubtaskFlatTextBoxStyle}">
                                                        <Setter Property="materialDesign:HintAssist.Hint" Value="Подзадача" />
                                                        <Setter Property="materialDesign:HintAssist.IsFloating" Value="False" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsDone}" Value="True">
                                                                <Setter Property="TextDecorations" Value="Strikethrough" />
                                                                <Setter Property="Opacity" Value="0.55" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBox.Style>
                                            </TextBox>

                                            <StackPanel Grid.Column="2"
                                                        Orientation="Horizontal"
                                                        VerticalAlignment="Center"
                                                        Margin="0,0,12,0">
                                                <Button Command="{Binding SetProgressCommand}"
                                                        Width="16" Height="10" Padding="0" Margin="0,0,3,0"
                                                        Cursor="Hand" Focusable="False" ToolTip="1/3"
                                                        Background="Transparent" BorderThickness="0">
                                                    <Button.CommandParameter>
                                                        <sys:Int32>33</sys:Int32>
                                                    </Button.CommandParameter>
                                                    <Border Width="16" Height="10" CornerRadius="2">
                                                        <Border.Style>
                                                            <Style TargetType="Border">
                                                                <Setter Property="Background" Value="#E0E0E0" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding ProgressPercent, Converter={StaticResource ProgressAtLeastConverter}, ConverterParameter=33}" Value="True">
                                                                        <Setter Property="Background" Value="{DynamicResource SecondaryHueMidBrush}" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>
                                                    </Border>
                                                </Button>
                                                <Button Command="{Binding SetProgressCommand}"
                                                        Width="16" Height="10" Padding="0" Margin="0,0,3,0"
                                                        Cursor="Hand" Focusable="False" ToolTip="2/3"
                                                        Background="Transparent" BorderThickness="0">
                                                    <Button.CommandParameter>
                                                        <sys:Int32>67</sys:Int32>
                                                    </Button.CommandParameter>
                                                    <Border Width="16" Height="10" CornerRadius="2">
                                                        <Border.Style>
                                                            <Style TargetType="Border">
                                                                <Setter Property="Background" Value="#E0E0E0" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding ProgressPercent, Converter={StaticResource ProgressAtLeastConverter}, ConverterParameter=67}" Value="True">
                                                                        <Setter Property="Background" Value="{DynamicResource SecondaryHueMidBrush}" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>
                                                    </Border>
                                                </Button>
                                                <Button Command="{Binding SetProgressCommand}"
                                                        Width="16" Height="10" Padding="0" Margin="0,0,3,0"
                                                        Cursor="Hand" Focusable="False" ToolTip="Готово"
                                                        Background="Transparent" BorderThickness="0">
                                                    <Button.CommandParameter>
                                                        <sys:Int32>100</sys:Int32>
                                                    </Button.CommandParameter>
                                                    <Border Width="16" Height="10" CornerRadius="2">
                                                        <Border.Style>
                                                            <Style TargetType="Border">
                                                                <Setter Property="Background" Value="#E0E0E0" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding ProgressPercent, Converter={StaticResource ProgressAtLeastConverter}, ConverterParameter=100}" Value="True">
                                                                        <Setter Property="Background" Value="{DynamicResource SecondaryHueMidBrush}" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>
                                                    </Border>
                                                </Button>
                                                <Button Command="{Binding SetProgressCommand}"
                                                        Width="16" Height="10" Padding="0"
                                                        Cursor="Hand" Focusable="False" ToolTip="Готово"
                                                        Background="Transparent" BorderThickness="0">
                                                    <Button.CommandParameter>
                                                        <sys:Int32>100</sys:Int32>
                                                    </Button.CommandParameter>
                                                    <Border Width="16" Height="10" CornerRadius="2">
                                                        <Border.Style>
                                                            <Style TargetType="Border">
                                                                <Setter Property="Background" Value="#E0E0E0" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding ProgressPercent, Converter={StaticResource ProgressAtLeastConverter}, ConverterParameter=100}" Value="True">
                                                                        <Setter Property="Background" Value="{DynamicResource SecondaryHueMidBrush}" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>
                                                    </Border>
                                                </Button>
                                            </StackPanel>

                                            <Grid Grid.Column="3" Margin="0,0,4,0" VerticalAlignment="Center">
                                                <ToggleButton x:Name="DueDateToggle"
                                                              Content="{Binding DueDateDisplay}"
                                                              Style="{StaticResource MaterialDesignFlatButton}"
                                                              Padding="6,2"
                                                              FontSize="12"
                                                              MinWidth="48"
                                                              ToolTip="Срок" />
                                                <Popup IsOpen="{Binding IsChecked, ElementName=DueDateToggle}"
                                                       PlacementTarget="{Binding ElementName=DueDateToggle}"
                                                       Placement="Bottom"
                                                       StaysOpen="False"
                                                       AllowsTransparency="True">
                                                    <materialDesign:Card Margin="0,4,0,0" Padding="8">
                                                        <StackPanel>
                                                            <Calendar SelectedDate="{Binding DueDate, Mode=TwoWay}"
                                                                      Language="ru-RU" />
                                                            <Button Content="Без срока"
                                                                    Margin="0,8,0,0"
                                                                    Style="{StaticResource MaterialDesignFlatButton}"
                                                                    Command="{Binding ClearDueDateCommand}"
                                                                    HorizontalAlignment="Stretch" />
                                                        </StackPanel>
                                                    </materialDesign:Card>
                                                </Popup>
                                            </Grid>

                                            <materialDesign:PopupBox Grid.Column="4"
                                                                    VerticalAlignment="Center"
                                                                    Padding="4"
                                                                    StaysOpen="False"
                                                                    ToolTip="Действия">
                                                <StackPanel>
                                                    <Button Content="Удалить"
                                                            Style="{StaticResource MaterialDesignFlatButton}"
                                                            Command="{Binding DataContext.RemoveSubtaskCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                            CommandParameter="{Binding}" />
                                                </StackPanel>
                                            </materialDesign:PopupBox>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <TextBox Text="{Binding NewSubtaskDescription, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 materialDesign:HintAssist.Hint="+ Новая подзадача"
                                 Margin="0,8,0,0">
                            <TextBox.InputBindings>
                                <KeyBinding Key="Enter" Command="{Binding AddSubtaskCommand}" />
                            </TextBox.InputBindings>
                        </TextBox>
                    </StackPanel>
                </Grid>
                </ScrollViewer>
            </TabItem>

            <TabItem ToolTip="Файлы"
                     IsEnabled="{Binding CanManageFiles}">
                <TabItem.Header>
                    <materialDesign:PackIcon Kind="FileOutline"
                                             Width="24"
                                             Height="24" />
                </TabItem.Header>
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel MaxWidth="480"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Top"
                                Margin="0,30,0,0">
                        <Button Content="Добавить файл"
                                Style="{StaticResource MaterialDesignOutlinedButton}"
                                HorizontalAlignment="Left"
                                Margin="0,0,0,16"
                                Command="{Binding AddFileCommand}" />

                        <TextBlock Text="Нет файлов"
                                   Margin="0,0,0,8">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock"
                                       BasedOn="{StaticResource MaterialDesignBody2TextBlock}">
                                    <Setter Property="Opacity" Value="0.6" />
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Files.Count}"
                                                     Value="0">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <ItemsControl ItemsSource="{Binding Files}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <materialDesign:PackIcon Grid.Column="0"
                                                                 Kind="FileOutline"
                                                                 Width="20"
                                                                 Height="20"
                                                                 VerticalAlignment="Center"
                                                                 Margin="0,0,8,0" />

                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding FileName}"
                                                   VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis" />

                                        <Button Grid.Column="2"
                                                Style="{StaticResource MaterialDesignIconButton}"
                                                ToolTip="Удалить"
                                                Command="{Binding DataContext.DeleteFileCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}">
                                            <materialDesign:PackIcon Kind="DeleteOutline"
                                                                     Width="20"
                                                                     Height="20" />
                                        </Button>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>
    </Grid>
</UserControl>
